<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokemon Types</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <% console.log(pokemons) %>
    <%{pokemons.forEach(pokemon => { %>
            <div class="home-box">
                <h2><%= pokemon.pokemon_name %></h2>
                <h2>Type: <%= pokemon.type%></h2>
            </div>
    <% })}%>
    <a href="/pokemons/new"><div>Add New Pokemon</div></a>
</body>
</html>