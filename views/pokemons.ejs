<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pokemon Types</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%{pokemons.forEach(pokemon => { %>
            <a href="/pokemons/<%= pokemon.id %>">
                <div class="home-box">
                    <h2><%= pokemon.pokemon_name %></h2>
                    <h2>Type: <%= pokemon.type%></h2>
                </div>
            </a>
    <% })}%>
    <a href="/pokemons/new"><div>Add New Pokemon</div></a>
</body>
</html>